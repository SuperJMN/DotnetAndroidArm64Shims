# Pinned upstream versions for Microsoft.Android.Sdk.Linux/35.0.105.
#
# This file targets the .NET 9 generation of the Android workload pack
# (the latest 35.0.x release). Every 35.0.x release Microsoft published
# (35.0.7 through 35.0.105) ships the same three x86_64 host binaries
# bit-for-bit, so this single shim release covers the entire 35.0.x series
# via compatibility.json. See compatibility.json::aliases for the mapping.
#
# Differences vs 36.1.53.env:
#   * AAPT2_VERSION_STRING is 2.19-11948202 (older AOSP build-tools snapshot
#     than 36.1.x's 2.20-13193326).
#   * The two .so binaries are identical — same upstream sources, same
#     symbol counts, same runtime ABI. We rebuild them anyway to keep the
#     release self-contained (one tarball per release tag, no cross-release
#     symlinks).

PACK_VERSION=35.0.105

AAPT2_VERSION_STRING="Android Asset Packaging Tool (aapt) 2.19-11948202"
AAPT2_AOSP_BUILD_ID=11948202

LIBZIP_VERSION=1.10.1
LIBZIPSHARP_SONAME_SUFFIX=3-3

MONO_POSIX_EXPECTED_SYMBOL_COUNT=346
LIBMONO_UNIX_EXPECTED_SYMBOL_COUNT=346
LIBZIPSHARPNATIVE_EXPECTED_SYMBOL_COUNT=127
