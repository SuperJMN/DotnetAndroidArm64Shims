# Pinned upstream versions for Microsoft.Android.Sdk.Linux/36.1.53.
#
# All values were extracted directly from the binaries shipped in the upstream
# x86_64 nupkg via `aapt2 version` and `strings`. See
# scripts/extract-reference-symbols.sh for the reproducible procedure.
#
# When bumping to a new pack version: copy this file, rename to <new>.env, and
# re-run extract-reference-symbols.sh — values that change indicate a real
# upstream rev that needs a matching shim rebuild.

PACK_VERSION=36.1.53

# aapt2: from `tools/Linux/aapt2 version`. Format is "<aapt-version>-<aosp-build-id>".
# The .NET MSBuild task caches this exact string in obj/aapt2.version and uses
# string equality to invalidate compiled .flata when it changes. Our shim must
# print the same line byte-for-byte.
AAPT2_VERSION_STRING="Android Asset Packaging Tool (aapt) 2.20-13193326"
AAPT2_AOSP_BUILD_ID=13193326

# libzip vendored inside libZipSharpNative-3-3.so (from `strings`).
LIBZIP_VERSION=1.10.1

# Soname suffix encoded in libZipSharpNative-3-3.so. If libzip's API revision
# changes upstream, this suffix becomes -3-4 / -3-5 / etc. and the .NET task
# import-by-literal-name breaks — that means a new shim release.
LIBZIPSHARP_SONAME_SUFFIX=3-3

# Mono.Posix: stripped binary, no embedded version. We pin by symbol parity
# instead (see verify-symbols.sh). The current x86_64 binary exports 346
# symbols including the helper_Mono_Posix_* and Mono_Posix_* families.
MONO_POSIX_EXPECTED_SYMBOL_COUNT=346

# Reference symbol counts for the .so shims (sanity floor — real check is the
# nm-diff in verify-symbols.sh).
LIBMONO_UNIX_EXPECTED_SYMBOL_COUNT=346
LIBZIPSHARPNATIVE_EXPECTED_SYMBOL_COUNT=127
